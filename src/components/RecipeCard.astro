---
interface Props {
  slug: string;
  title: string;
  subtitle: string;
  number: number;
  tierClass: string;  // chill / legit / real-deal / ordeal
}

const { slug, title, subtitle, number, tierClass } = Astro.props;
---
<a href={`/recipes/${slug}/`} class={`recipe-card ${tierClass}`}>
  <span class="recipe-number">#{String(number).padStart(2, '0')}</span>
  <h3>{title}</h3>
  <p class="recipe-subtitle">{subtitle}</p>
</a>

<style>
  .recipe-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    position: relative;
    overflow: hidden;
  }

  .recipe-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
  }

  .recipe-card.chill::before     { background: var(--tier-chill); }
  .recipe-card.legit::before     { background: var(--tier-legit); }
  .recipe-card.real-deal::before { background: var(--tier-real-deal); }
  .recipe-card.ordeal::before    { background: var(--tier-ordeal); }

  .recipe-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .recipe-number {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  .recipe-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: 0.25rem 0 0.35rem;
  }

  .recipe-subtitle {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.4;
  }
</style>
