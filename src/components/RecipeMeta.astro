---
import { cuisineToSlug } from '../lib/cuisine';
import { redactHtml } from '../lib/redact.mjs';

interface Props {
  tier: string;
  difficultyText: string;
  totalTime: string;
  cuisine?: string;
  activeTimeMinutes?: number;
  recipeYield?: string;
  dietary?: string[];
}

const {
  tier,
  difficultyText,
  totalTime,
  cuisine,
  activeTimeMinutes,
  recipeYield,
  dietary,
} = Astro.props;

const tierClass = {
  'CHILL': 'chill',
  'LEGIT': 'legit',
  'THE REAL DEAL': 'real-deal',
  'A FUCKING ORDEAL': 'ordeal',
}[tier] || 'legit';

function formatMinutes(min?: number): string | null {
  if (min == null) return null;
  if (min < 60) return `${min} min`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m === 0 ? `${h} hr` : `${h} hr ${m} min`;
}

const activeLabel = formatMinutes(activeTimeMinutes);

const dietaryLabels: Record<string, string> = {
  'vegan': 'Vegan',
  'dairy-free': 'Dairy-free',
  'egg-free': 'Egg-free',
  'gluten-free': 'Gluten-free',
  'contains-alcohol': 'Contains alcohol',
  'contains-nuts': 'Contains nuts',
  'contains-soy': 'Contains soy',
  'contains-sesame': 'Contains sesame',
  'contains-wheat': 'Contains wheat',
};
---
<aside class="recipe-meta">
  <div class="meta-top">
    <span class={`tier-badge ${tierClass}`} set:html={redactHtml(tier)} />
    {cuisine && (
      <a class="meta-cuisine" href={`/cuisine/${cuisineToSlug(cuisine)}/`}>{cuisine}</a>
    )}
  </div>

  <p class="meta-difficulty" set:html={redactHtml(difficultyText)} />

  <dl class="meta-grid">
    {activeLabel && (
      <div class="meta-item">
        <dt>Active time</dt>
        <dd>{activeLabel}</dd>
      </div>
    )}
    <div class="meta-item">
      <dt>Total time</dt>
      <dd set:html={redactHtml(totalTime)} />
    </div>
    {recipeYield && (
      <div class="meta-item">
        <dt>Yield</dt>
        <dd>{recipeYield}</dd>
      </div>
    )}
  </dl>

  {dietary && dietary.length > 0 && (
    <ul class="dietary-chips" aria-label="Dietary information">
      {dietary.map(tag => (
        <li class={`chip chip-${tag.startsWith('contains-') ? 'contains' : 'free'}`}>
          {dietaryLabels[tag] ?? tag}
        </li>
      ))}
    </ul>
  )}
</aside>

<style>
  .recipe-meta {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.25rem 1rem;
    margin-bottom: 2rem;
  }

  .meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.85rem;
  }

  .meta-cuisine {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .meta-cuisine:hover {
    color: var(--color-accent);
  }

  .meta-difficulty {
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.75rem 1.25rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-border);
  }

  .meta-item dt {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.15rem;
  }

  .meta-item dd {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .dietary-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }

  .chip {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }

  .chip-free {
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-color: var(--color-accent-light);
  }

  .chip-contains {
    background: transparent;
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .meta-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
