---
interface NavTarget {
  slug: string;
  title: string;
}

interface Props {
  prev: NavTarget | null;
  next: NavTarget | null;
}

const { prev, next } = Astro.props;

const prevHref = prev ? `/recipes/${prev.slug}` : null;
const nextHref = next ? `/recipes/${next.slug}` : null;
---
<nav
  class="recipe-nav"
  aria-label="Recipe navigation"
  data-prev={prevHref}
  data-next={nextHref}
>
  {prev && prevHref && (
    <a href={prevHref} class="nav-prev" rel="prev">
      <span class="nav-dir">&larr; Previous</span>
      <span class="nav-title">{prev.title}</span>
    </a>
  )}
  {next && nextHref && (
    <a href={nextHref} class="nav-next" rel="next">
      <span class="nav-dir">Next &rarr;</span>
      <span class="nav-title">{next.title}</span>
    </a>
  )}
</nav>

<script>
  // Keyboard nav: ← previous, → next. Triggers the link's own click so
  // Astro's ClientRouter intercepts it for an SPA-style transition (and
  // falls back to a normal navigation in browsers without View Transitions).
  // Skip when the user is typing or holding a modifier.
  function isTypingTarget(el: EventTarget | null): boolean {
    if (!(el instanceof HTMLElement)) return false;
    const tag = el.tagName;
    return tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || el.isContentEditable;
  }

  function navFromKey(e: KeyboardEvent) {
    if (e.altKey || e.ctrlKey || e.metaKey || e.shiftKey) return;
    if (isTypingTarget(e.target)) return;

    const selector =
      e.key === 'ArrowLeft' ? '.recipe-nav a[rel="prev"]' :
      e.key === 'ArrowRight' ? '.recipe-nav a[rel="next"]' :
      null;
    if (!selector) return;

    const link = document.querySelector<HTMLAnchorElement>(selector);
    if (!link) return;

    e.preventDefault();
    link.click();
  }

  document.addEventListener('keydown', navFromKey);
</script>

<style>
  .recipe-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .recipe-nav a {
    text-decoration: none;
    color: var(--color-text);
    padding: 0.75rem;
    border-radius: 6px;
    transition: background 0.15s ease;
  }

  .recipe-nav a:hover {
    background: var(--color-surface);
  }

  .nav-prev { text-align: left; }
  .nav-next { text-align: right; margin-left: auto; }

  .nav-dir {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.15rem;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
  }

  @media (max-width: 640px) {
    .recipe-nav { flex-direction: column; }
    .nav-next { text-align: left; margin-left: 0; }
  }
</style>
