---
// Renders a Home › Tier › Recipe trail at the top of recipe pages,
// plus a schema.org BreadcrumbList JSON-LD block alongside it.
//
// Tier link target is a homepage anchor (#chill, #legit, #real-deal,
// #ordeal) — those IDs are set on each tier-section in index.astro.
// When Phase 2 filtered tier pages land, swap to dedicated routes.
interface Props {
  tier: string;          // CHILL / LEGIT / THE REAL DEAL / A FUCKING ORDEAL
  recipeTitle: string;
  recipeUrl: string;     // canonical absolute URL of the recipe page
  siteUrl: string;       // absolute base, e.g. https://icecreamtofightwith.com
}

const { tier, recipeTitle, recipeUrl, siteUrl } = Astro.props;

const TIER_ANCHOR: Record<string, string> = {
  'CHILL': 'chill',
  'LEGIT': 'legit',
  'THE REAL DEAL': 'real-deal',
  'A FUCKING ORDEAL': 'ordeal',
};

const tierAnchor = TIER_ANCHOR[tier] ?? 'legit';
const tierHref = `/#${tierAnchor}`;
const tierAbsoluteUrl = new URL(tierHref, siteUrl).toString();
const homeUrl = new URL('/', siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org/',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: homeUrl },
    { '@type': 'ListItem', position: 2, name: tier, item: tierAbsoluteUrl },
    { '@type': 'ListItem', position: 3, name: recipeTitle, item: recipeUrl },
  ],
};
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Home</a></li>
    <li aria-hidden="true" class="sep">›</li>
    <li><a href={tierHref}>{tier}</a></li>
    <li aria-hidden="true" class="sep">›</li>
    <li aria-current="page">{recipeTitle}</li>
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<style>
  .breadcrumbs {
    margin: 0 0 1.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: baseline;
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumbs a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .breadcrumbs .sep {
    color: var(--color-border);
    user-select: none;
  }

  .breadcrumbs [aria-current="page"] {
    color: var(--color-text);
    font-weight: 500;
    /* Long recipe names should wrap rather than overflow on mobile */
    overflow-wrap: anywhere;
  }
</style>
