---
import RecipeCard from './RecipeCard.astro';
import type { CollectionEntry } from 'astro:content';

type Recipe = CollectionEntry<'recipes'>;

interface Props {
  current: Recipe;
  all: Recipe[];
  count?: number;
}

const { current, all, count = 3 } = Astro.props;

// Weighted scoring against the current recipe:
//   same cuisine        = 3
//   each shared dietary = 1
//   same tier           = 0.5 (tiebreaker only)
function score(other: Recipe): number {
  let s = 0;
  if (current.data.cuisine && other.data.cuisine === current.data.cuisine) s += 3;
  const currentDietary = current.data.dietary ?? [];
  const otherDietary = other.data.dietary ?? [];
  for (const tag of otherDietary) if (currentDietary.includes(tag)) s += 1;
  if (other.data.tier === current.data.tier) s += 0.5;
  return s;
}

// Deterministic per-recipe pseudo-shuffle so fallback picks are stable
// across builds but vary recipe-to-recipe.
function shuffleKey(slug: string, n: number): number {
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) >>> 0;
  return (n * 2654435761 + h) >>> 0;
}

const others = all.filter(r => r.data.recipeSlug !== current.data.recipeSlug);
const scored = others
  .map(r => ({ r, s: score(r) }))
  .sort((a, b) => b.s - a.s || a.r.data.recipeNumber - b.r.data.recipeNumber);

const real = scored.filter(x => x.s > 0).slice(0, count).map(x => x.r);
const fallbackPool = scored.filter(x => x.s === 0).map(x => x.r);
fallbackPool.sort((a, b) =>
  shuffleKey(current.data.recipeSlug, a.data.recipeNumber) -
  shuffleKey(current.data.recipeSlug, b.data.recipeNumber)
);
const filled = [...real, ...fallbackPool.slice(0, Math.max(0, count - real.length))];

const tierClassMap: Record<string, string> = {
  'CHILL': 'chill',
  'LEGIT': 'legit',
  'THE REAL DEAL': 'real-deal',
  'A FUCKING ORDEAL': 'ordeal',
};
---
{filled.length > 0 && (
  <section class="related-recipes" aria-labelledby="related-heading">
    <h2 id="related-heading">If you liked this, try:</h2>
    <div class="related-grid">
      {filled.map(recipe => (
        <RecipeCard
          slug={recipe.data.recipeSlug}
          title={recipe.data.title}
          subtitle={recipe.data.subtitle}
          number={recipe.data.recipeNumber}
          tierClass={tierClassMap[recipe.data.tier] ?? 'legit'}
        />
      ))}
    </div>
  </section>
)}

<style>
  .related-recipes {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .related-recipes h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
