---
import Base from '../layouts/Base.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { redactHtml } from '../lib/redact.mjs';

const recipes = await getCollection('recipes');
recipes.sort((a, b) => a.data.recipeNumber - b.data.recipeNumber);

const TIER_CLASS: Record<string, string> = {
  'CHILL': 'chill',
  'LEGIT': 'legit',
  'THE REAL DEAL': 'real-deal',
  'A FUCKING ORDEAL': 'ordeal',
};
const TIERS = ['CHILL', 'LEGIT', 'THE REAL DEAL', 'A FUCKING ORDEAL'] as const;

// Build the filter UI option lists from the actual corpus, alphabetical.
const cuisines = [...new Set(recipes.map(r => r.data.cuisine).filter((c): c is string => Boolean(c)))].sort();

// Dietary tags split into "is" (positive identity) and "is not" (allergen/restriction)
const DIETARY_YES: Array<[string, string]> = [
  ['vegan', 'Vegan'],
  ['dairy-free', 'Dairy-free'],
  ['egg-free', 'Egg-free'],
  ['gluten-free', 'Gluten-free'],
];
const DIETARY_NO: Array<[string, string]> = [
  ['contains-alcohol', 'No alcohol'],
  ['contains-nuts', 'No nuts'],
  ['contains-soy', 'No soy'],
  ['contains-sesame', 'No sesame'],
  ['contains-wheat', 'No wheat'],
];

const TIME_BUDGETS: Array<[number, string]> = [
  [60, 'Under 1 hour'],
  [180, 'Under 3 hours'],
  [360, 'Under 6 hours'],
];

const tiers = TIERS.map(name => ({
  name,
  class: TIER_CLASS[name],
  recipes: recipes.filter(r => r.data.tier === name),
}));
---
<Base title="Ice Cream to Fight With" description="Recipes You'll Fuck Up At Least Once">

  <header class="hero">
    <div class="hero-inner">
      <h1>Ice Cream<br /><span class="accent">to Fight With</span></h1>
      <p class="tagline" set:html={redactHtml("Recipes You'll Fuck Up At Least Once")} />
    </div>
  </header>

  <main class="page-container wide">

    <section class="filters" aria-label="Filter recipes">
      <details class="filter-group">
        <summary>Tier <span class="filter-hint">multi-select</span></summary>
        <div class="chip-row">
          {TIERS.map(name => (
            <button type="button" class="chip" data-filter="tier" data-value={name} aria-pressed="false" set:html={redactHtml(name)} />
          ))}
        </div>
      </details>

      <details class="filter-group">
        <summary>Cuisine <span class="filter-hint">multi-select</span></summary>
        <div class="chip-row">
          {cuisines.map(cuisine => (
            <button type="button" class="chip" data-filter="cuisine" data-value={cuisine} aria-pressed="false">{cuisine}</button>
          ))}
        </div>
      </details>

      <details class="filter-group">
        <summary>Dietary <span class="filter-hint">multi-select</span></summary>
        <div class="dietary-groups">
          <div class="dietary-subgroup">
            <p class="dietary-label">Recipes that are:</p>
            <div class="chip-row">
              {DIETARY_YES.map(([tag, label]) => (
                <button type="button" class="chip" data-filter="dietary-yes" data-value={tag} aria-pressed="false">{label}</button>
              ))}
            </div>
          </div>
          <div class="dietary-subgroup">
            <p class="dietary-label">Avoiding:</p>
            <div class="chip-row">
              {DIETARY_NO.map(([tag, label]) => (
                <button type="button" class="chip" data-filter="dietary-no" data-value={tag} aria-pressed="false">{label}</button>
              ))}
            </div>
          </div>
        </div>
      </details>

      <details class="filter-group">
        <summary>Time budget <span class="filter-hint">single-select</span></summary>
        <div class="chip-row">
          {TIME_BUDGETS.map(([minutes, label]) => (
            <button type="button" class="chip" data-filter="time" data-value={minutes} aria-pressed="false">{label}</button>
          ))}
        </div>
      </details>

      <div class="filter-actions">
        <button type="button" id="filters-clear" class="filter-clear" hidden>Clear filters</button>
        <span id="filter-count" class="filter-count" aria-live="polite"></span>
      </div>
    </section>

    {tiers.map(tier => (
      <section class="tier-section" id={tier.class} data-tier-section={tier.name}>
        <div class="tier-header">
          <a href={`/tier/${tier.class}/`} class="tier-link">
            <span class={`tier-badge ${tier.class}`} set:html={redactHtml(tier.name)} />
          </a>
          <span class="tier-count">{tier.recipes.length} recipes</span>
        </div>
        <div class="recipe-grid">
          {tier.recipes.map(recipe => (
            <div
              class="recipe-card-wrap"
              data-recipe-tier={recipe.data.tier}
              data-recipe-cuisine={recipe.data.cuisine ?? ''}
              data-recipe-dietary={(recipe.data.dietary ?? []).join(' ')}
              data-recipe-max-minutes={recipe.data.totalTimeMinutesMax ?? ''}
            >
              <RecipeCard
                slug={recipe.data.recipeSlug}
                title={recipe.data.title}
                subtitle={recipe.data.subtitle}
                number={recipe.data.recipeNumber}
                tierClass={tier.class}
              />
            </div>
          ))}
        </div>
      </section>
    ))}

    <p id="empty-state" class="empty-state" hidden>No recipes match every filter. Loosen one and try again.</p>

  </main>

</Base>

<script>
  // Homepage filter island. Reads/writes URL state, AND across dimensions,
  // OR within each. Time uses totalTimeMinutesMax so the filter is honest
  // about worst-case duration (no surprise long recipes).
  type FilterState = {
    tier: Set<string>;
    cuisine: Set<string>;
    dietaryYes: Set<string>;
    dietaryNo: Set<string>;
    maxMinutes: number | null;
  };

  function readUrl(): FilterState {
    const p = new URLSearchParams(window.location.search);
    const split = (k: string) => new Set((p.get(k) ?? '').split(',').filter(Boolean));
    const time = p.get('time');
    return {
      tier: split('tier'),
      cuisine: split('cuisine'),
      dietaryYes: split('dietary-yes'),
      dietaryNo: split('dietary-no'),
      maxMinutes: time ? parseInt(time, 10) : null,
    };
  }

  function writeUrl(state: FilterState) {
    const p = new URLSearchParams();
    if (state.tier.size) p.set('tier', [...state.tier].join(','));
    if (state.cuisine.size) p.set('cuisine', [...state.cuisine].join(','));
    if (state.dietaryYes.size) p.set('dietary-yes', [...state.dietaryYes].join(','));
    if (state.dietaryNo.size) p.set('dietary-no', [...state.dietaryNo].join(','));
    if (state.maxMinutes != null) p.set('time', String(state.maxMinutes));
    const qs = p.toString();
    const url = qs ? `${location.pathname}?${qs}` : location.pathname;
    history.replaceState({}, '', url);
  }

  function activeCount(state: FilterState): number {
    return state.tier.size + state.cuisine.size + state.dietaryYes.size + state.dietaryNo.size + (state.maxMinutes == null ? 0 : 1);
  }

  function applyFilters(state: FilterState) {
    const cards = document.querySelectorAll<HTMLElement>('.recipe-card-wrap');
    let visible = 0;
    cards.forEach(card => {
      let show = true;
      if (state.tier.size && !state.tier.has(card.dataset.recipeTier ?? '')) show = false;
      if (show && state.cuisine.size && !state.cuisine.has(card.dataset.recipeCuisine ?? '')) show = false;
      const dietary = (card.dataset.recipeDietary ?? '').split(' ').filter(Boolean);
      if (show) for (const tag of state.dietaryYes) if (!dietary.includes(tag)) { show = false; break; }
      if (show) for (const tag of state.dietaryNo) if (dietary.includes(tag)) { show = false; break; }
      if (show && state.maxMinutes != null) {
        const mm = parseInt(card.dataset.recipeMaxMinutes || '0', 10);
        if (mm > state.maxMinutes) show = false;
      }
      card.hidden = !show;
      if (show) visible++;
    });
    // Auto-hide whole tier sections that have nothing left
    document.querySelectorAll<HTMLElement>('[data-tier-section]').forEach(section => {
      const any = section.querySelectorAll('.recipe-card-wrap:not([hidden])').length > 0;
      section.hidden = !any;
    });
    const empty = document.getElementById('empty-state');
    if (empty) empty.hidden = visible > 0;
    const counter = document.getElementById('filter-count');
    if (counter) {
      const n = activeCount(state);
      counter.textContent = n === 0 ? '' : `${visible} of 28 recipes match`;
    }
    const clear = document.getElementById('filters-clear');
    if (clear) clear.hidden = activeCount(state) === 0;
  }

  function syncChipPressedStates(state: FilterState) {
    const stateMap: Record<string, Set<string> | undefined> = {
      'tier': state.tier,
      'cuisine': state.cuisine,
      'dietary-yes': state.dietaryYes,
      'dietary-no': state.dietaryNo,
    };
    document.querySelectorAll<HTMLButtonElement>('.chip[data-filter]').forEach(btn => {
      const filter = btn.dataset.filter ?? '';
      const value = btn.dataset.value ?? '';
      if (filter === 'time') {
        btn.setAttribute('aria-pressed', String(parseInt(value, 10) === state.maxMinutes));
      } else {
        const set = stateMap[filter];
        btn.setAttribute('aria-pressed', String(set?.has(value) ?? false));
      }
    });
  }

  function init() {
    if (!document.querySelector('.filters')) return; // Only on homepage
    const state = readUrl();

    document.querySelectorAll<HTMLButtonElement>('.chip[data-filter]').forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? '';
        const value = btn.dataset.value ?? '';
        if (filter === 'time') {
          const minutes = parseInt(value, 10);
          state.maxMinutes = state.maxMinutes === minutes ? null : minutes;
        } else {
          const set = ({
            'tier': state.tier,
            'cuisine': state.cuisine,
            'dietary-yes': state.dietaryYes,
            'dietary-no': state.dietaryNo,
          })[filter];
          if (set) (set.has(value) ? set.delete(value) : set.add(value));
        }
        writeUrl(state);
        syncChipPressedStates(state);
        applyFilters(state);
      });
    });

    document.getElementById('filters-clear')?.addEventListener('click', () => {
      state.tier.clear();
      state.cuisine.clear();
      state.dietaryYes.clear();
      state.dietaryNo.clear();
      state.maxMinutes = null;
      writeUrl(state);
      syncChipPressedStates(state);
      applyFilters(state);
    });

    syncChipPressedStates(state);
    applyFilters(state);
  }

  document.addEventListener('astro:page-load', init);
</script>

<style>
  .hero {
    background: linear-gradient(145deg, #2d2a26 0%, #4a3f35 100%);
    color: #faf7f2;
    padding: 5rem 2rem 4rem;
    text-align: center;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: 3.5rem;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .hero .accent {
    color: var(--color-accent);
    font-style: italic;
  }

  .tagline {
    font-size: 1.1rem;
    color: #b8aea4;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  /* --- Filters --- */
  .filters {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0 2rem;
    display: grid;
    gap: 0.5rem;
  }

  .filter-group {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.65rem;
  }

  .filter-group:last-of-type {
    border-bottom: none;
    padding-bottom: 0;
  }

  .filter-group summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.35rem 0;
    list-style: revert; /* keep native marker for affordance */
  }

  .filter-hint {
    font-weight: 400;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: 0.5rem;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .chip {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    font: inherit;
    font-size: 0.8rem;
    color: var(--color-text);
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .chip:hover {
    border-color: var(--color-accent);
  }

  .chip[aria-pressed="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .dietary-groups {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .dietary-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0 0 0.35rem;
  }

  .filter-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
    min-height: 1.5rem;
  }

  .filter-clear {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    font: inherit;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    cursor: pointer;
  }

  .filter-clear:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .filter-count {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  /* --- Tier sections --- */
  .tier-section {
    margin-bottom: 3rem;
  }

  .tier-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .tier-count {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .tier-link {
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .tier-link:hover {
    opacity: 0.85;
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .recipe-card-wrap[hidden] {
    display: none;
  }

  @media (max-width: 640px) {
    .hero h1 { font-size: 2.5rem; }
    .hero { padding: 3.5rem 1.5rem 3rem; }
    .recipe-grid { grid-template-columns: 1fr; }
  }
</style>
