---
import Base from '../layouts/Base.astro';
import Search from 'astro-pagefind/components/Search.astro';
---
<Base title="Search — Ice Cream to Fight With" description="Search all 28 recipes by name, ingredient, technique, or cultural context.">
  <main class="page-container">
    <header class="search-header">
      <h1>Search</h1>
      <p class="search-blurb">Try a flavor, a technique, a cultural origin, or just a vibe. Live search across all 28 recipes — no backend, no fetch, just an index that ships with the site.</p>
    </header>

    <Search
      id="search"
      className="pagefind-ui"
      uiOptions={{
        showImages: false,
        excerptLength: 28,
        resetStyles: false,
        showSubResults: false,
        placeholder: 'Search recipes…',
      }}
    />
  </main>
</Base>

<style is:global>
  /* Tone Pagefind's default UI down to match the site palette */
  .pagefind-ui {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-bg);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: var(--font-body);
    --pagefind-ui-image-side-length: 0px;
  }
</style>

<style>
  .search-header {
    margin-bottom: 2rem;
  }

  .search-header h1 {
    font-family: var(--font-display);
    font-size: 2.25rem;
    margin: 0.5rem 0;
  }

  .search-blurb {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.55;
  }
</style>
