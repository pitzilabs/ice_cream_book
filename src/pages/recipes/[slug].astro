---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RecipeMeta from '../../components/RecipeMeta.astro';
import RecipeNav from '../../components/RecipeNav.astro';
import RecipeJsonLd from '../../components/RecipeJsonLd.astro';
import RelatedRecipes from '../../components/RelatedRecipes.astro';
import { Image, getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import { redactPlain } from '../../lib/redact.mjs';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map(recipe => ({
    params: { slug: recipe.data.recipeSlug },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await recipe.render();

// Find prev/next recipes. Walk all 28 in recipeNumber order (01 → 28).
const allRecipes = await getCollection('recipes');
allRecipes.sort((a, b) => a.data.recipeNumber - b.data.recipeNumber);
const idx = allRecipes.findIndex(r => r.data.recipeSlug === recipe.data.recipeSlug);
const prev = idx > 0 ? allRecipes[idx - 1] : null;
const next = idx >= 0 && idx < allRecipes.length - 1 ? allRecipes[idx + 1] : null;

// Absolute URLs for JSON-LD. Astro.site is set in astro.config.mjs.
const canonicalUrl = new URL(`/recipes/${recipe.data.recipeSlug}/`, Astro.site).toString();
let imageUrl: string | undefined;
if (recipe.data.illustration) {
  const optimized = await getImage({ src: recipe.data.illustration, width: 1200 });
  imageUrl = new URL(optimized.src, Astro.site).toString();
}
---
<Base title={`${recipe.data.title} — Ice Cream to Fight With`} description={recipe.data.subtitle}>
  <RecipeJsonLd
    title={recipe.data.title}
    subtitle={recipe.data.subtitle}
    url={canonicalUrl}
    imageUrl={imageUrl}
    cuisine={recipe.data.cuisine}
    tier={recipe.data.tier}
    activeTimeMinutes={recipe.data.activeTimeMinutes}
    totalTimeMinutesMin={recipe.data.totalTimeMinutesMin}
    totalTimeMinutesMax={recipe.data.totalTimeMinutesMax}
    recipeYield={recipe.data.recipeYield}
    dietary={recipe.data.dietary}
  />

  <article class="page-container" data-pagefind-body data-pagefind-meta={`title:${recipe.data.title},cuisine:${recipe.data.cuisine ?? ''},tier:${redactPlain(recipe.data.tier)}`}>
    <Breadcrumbs
      tier={recipe.data.tier}
      recipeTitle={recipe.data.title}
      recipeUrl={canonicalUrl}
      siteUrl={Astro.site!.toString()}
    />

    {recipe.data.illustration && (
      <figure class="recipe-hero">
        <Image
          src={recipe.data.illustration}
          alt={`Illustration for ${recipe.data.title}`}
          widths={[480, 800, 1200, 1800]}
          sizes="(max-width: 768px) 100vw, min(1200px, 100vw)"
          loading="eager"
        />
      </figure>
    )}

    <header class="recipe-header">
      <span class="recipe-number">Recipe #{String(recipe.data.recipeNumber).padStart(2, '0')}</span>
      <h1>{recipe.data.title}</h1>
      <p class="subtitle">{recipe.data.subtitle}</p>
    </header>

    <RecipeMeta
      tier={recipe.data.tier}
      difficultyText={recipe.data.difficultyText}
      totalTime={recipe.data.totalTime}
      cuisine={recipe.data.cuisine}
      activeTimeMinutes={recipe.data.activeTimeMinutes}
      recipeYield={recipe.data.recipeYield}
      dietary={recipe.data.dietary}
    />

    <div class="recipe-body">
      <Content />
    </div>

    <RelatedRecipes current={recipe} all={allRecipes} />

    <RecipeNav
      prev={prev ? { slug: prev.data.recipeSlug, title: prev.data.title } : null}
      next={next ? { slug: next.data.recipeSlug, title: next.data.title } : null}
    />
  </article>

</Base>

<style>
  .recipe-hero {
    margin: 0 0 2rem;
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .recipe-hero img {
    display: block;
    width: 100%;
    height: auto;
  }

  .recipe-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .recipe-number {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: 0.5rem;
  }

  .recipe-header h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    margin: 0.5rem 0 0.25rem;
    line-height: 1.15;
  }

  .subtitle {
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 640px) {
    .recipe-header h1 { font-size: 1.85rem; }
  }
</style>
