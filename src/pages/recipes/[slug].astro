---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map(recipe => ({
    params: { slug: recipe.data.recipeSlug },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await recipe.render();

const tierClass = {
  'CHILL': 'chill',
  'LEGIT': 'legit',
  'THE REAL DEAL': 'real-deal',
  'A FUCKING ORDEAL': 'ordeal',
}[recipe.data.tier] || 'legit';

// Find prev/next recipes
const allRecipes = await getCollection('recipes');
allRecipes.sort((a, b) => a.data.recipeNumber - b.data.recipeNumber);
const idx = allRecipes.findIndex(r => r.data.slug === recipe.data.recipeSlug);
const prev = idx > 0 ? allRecipes[idx - 1] : null;
const next = idx < allRecipes.length - 1 ? allRecipes[idx + 1] : null;
---
<Base title={`${recipe.data.title} — Ice Cream to Fight Over`} description={recipe.data.subtitle}>

  <article class="page-container">
    <header class="recipe-header">
      <span class={`tier-badge ${tierClass}`}>{recipe.data.tier}</span>
      <span class="recipe-number">Recipe #{String(recipe.data.recipeNumber).padStart(2, '0')}</span>
      <h1>{recipe.data.title}</h1>
      <p class="subtitle">{recipe.data.subtitle}</p>

      <div class="meta-bar">
        <div class="meta-item">
          <span class="meta-label">Difficulty</span>
          <span class="meta-value">{recipe.data.difficultyText}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Total Time</span>
          <span class="meta-value">{recipe.data.totalTime}</span>
        </div>
      </div>
    </header>

    <div class="recipe-body">
      <Content />
    </div>

    <nav class="recipe-nav">
      {prev && (
        <a href={`/recipes/${prev.data.slug}`} class="nav-prev">
          <span class="nav-dir">&larr; Previous</span>
          <span class="nav-title">{prev.data.title}</span>
        </a>
      )}
      {next && (
        <a href={`/recipes/${next.data.slug}`} class="nav-next">
          <span class="nav-dir">Next &rarr;</span>
          <span class="nav-title">{next.data.title}</span>
        </a>
      )}
    </nav>
  </article>

</Base>

<style>
  .recipe-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .recipe-number {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: 0.5rem;
  }

  .recipe-header h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    margin: 0.5rem 0 0.25rem;
    line-height: 1.15;
  }

  .subtitle {
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .meta-bar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
  }

  .meta-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .meta-value {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .recipe-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .recipe-nav a {
    text-decoration: none;
    color: var(--color-text);
    padding: 0.75rem;
    border-radius: 6px;
    transition: background 0.15s ease;
  }

  .recipe-nav a:hover {
    background: var(--color-surface);
  }

  .nav-prev { text-align: left; }
  .nav-next { text-align: right; margin-left: auto; }

  .nav-dir {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.15rem;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
  }

  @media (max-width: 640px) {
    .recipe-header h1 { font-size: 1.85rem; }
    .recipe-nav { flex-direction: column; }
    .nav-next { text-align: left; margin-left: 0; }
  }
</style>
