---
import Base from '../../layouts/Base.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { redactHtml } from '../../lib/redact.mjs';

// Astro hoists getStaticPaths into a separate scope, so TIERS lives
// inside the function. The TS interface stays at module scope.
interface TierMeta {
  slug: string;
  name: string;
  description: string;
}

export async function getStaticPaths() {
  const TIERS = [
    {
      slug: 'chill',
      name: 'CHILL',
      description: "You're making tea, basically. Simple techniques, minimal failure points, maximum reward. Start here if you've never made ice cream before.",
    },
    {
      slug: 'legit',
      name: 'LEGIT',
      description: "Real ice cream making. Custard bases, tempering, infusions. You'll learn technique here, and the results are worth the effort.",
    },
    {
      slug: 'real-deal',
      name: 'THE REAL DEAL',
      description: "Multiple components, timing choreography, and at least one moment where you'll question your life choices. The smug satisfaction when you nail it is unmatched.",
    },
    {
      slug: 'ordeal',
      name: 'A FUCKING ORDEAL',
      description: "Yeasted doughs, multi-day processes, rare seasonal ingredients that spoil in 48 hours. You absolute lunatic. We love you for it.",
    },
  ];
  return TIERS.map(tier => ({
    params: { slug: tier.slug },
    props: { tier },
  }));
}

const { tier } = Astro.props as { tier: TierMeta };
const recipes = (await getCollection('recipes'))
  .filter(r => r.data.tier === tier.name)
  .sort((a, b) => a.data.recipeNumber - b.data.recipeNumber);
---
<Base title={`${tier.name} — Ice Cream to Fight With`} description={tier.description}>
  <main class="page-container wide">
    <header class="tier-page-header">
      <span class={`tier-badge ${tier.slug}`} set:html={redactHtml(tier.name)} />
      <span class="tier-page-count">{recipes.length} {recipes.length === 1 ? 'recipe' : 'recipes'}</span>
      <p class="tier-page-description">{tier.description}</p>
    </header>

    <div class="recipe-grid">
      {recipes.map(recipe => (
        <RecipeCard
          slug={recipe.data.recipeSlug}
          title={recipe.data.title}
          subtitle={recipe.data.subtitle}
          number={recipe.data.recipeNumber}
          tierClass={tier.slug}
        />
      ))}
    </div>
  </main>
</Base>

<style>
  .tier-page-header {
    margin: 1rem 0 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 0.75rem 1rem;
    align-items: center;
  }

  .tier-page-count {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .tier-page-description {
    grid-column: 1 / -1;
    margin: 0.5rem 0 0;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .tier-page-header { grid-template-columns: auto 1fr; }
    .recipe-grid { grid-template-columns: 1fr; }
  }
</style>
