---
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import { redactPlain } from '../lib/redact.mjs';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Ice Cream to Fight With', description = 'Recipes You\'ll Fuck Up At Least Once' } = Astro.props;

// <title> and meta description are plain-text sinks — bowdlerize here,
// centrally, so no page has to remember to. Visible text uses redactHtml.
const safeTitle = redactPlain(title);
const safeDescription = redactPlain(description);

// Slugs are baked into the page at build time so the "Surprise me" button
// can pick a random recipe with zero network round-trips.
const allRecipes = await getCollection('recipes');
const recipeSlugs = allRecipes.map(r => r.data.recipeSlug);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={safeDescription} />
  <title>{safeTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="alternate" type="application/rss+xml" title="Ice Cream to Fight With" href="/rss.xml" />

  <script is:inline>
    // FOUC prevention: apply saved theme before first paint.
    // Allowed values: 'light' | 'dark'. Anything else means "follow system",
    // which the CSS prefers-color-scheme media query handles.
    (() => {
      try {
        const saved = localStorage.getItem('theme');
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.dataset.theme = saved;
        }
      } catch {}
    })();
  </script>

  <ClientRouter />
  <style is:global>
    :root {
      /* Light palette — warm, food-inspired */
      --color-bg: #faf7f2;
      --color-surface: #ffffff;
      --color-text: #2d2a26;
      --color-text-muted: #6b6560;
      --color-accent: #c4533a;
      --color-accent-light: #f0d5cf;
      --color-border: #e8e2da;
      --color-nav-bg: rgba(250, 247, 242, 0.92);

      /* Tier brand colors — same in both modes */
      --tier-chill: #4a9e82;
      --tier-legit: #d4a12e;
      --tier-real-deal: #d07030;
      --tier-ordeal: #c4533a;

      /* Type scale */
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body: 'Space Grotesk', system-ui, sans-serif;
      --font-mono: 'JetBrains Mono', monospace;

      color-scheme: light;
    }

    /* Dark palette — applies when:
       1. User has chosen dark explicitly (data-theme="dark"), OR
       2. User has no preference set AND system is dark.
       :not([data-theme="light"]) keeps the media query from overriding
       an explicit light choice. */
    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) {
        --color-bg: #1c1a17;
        --color-surface: #28241f;
        --color-text: #ece5da;
        --color-text-muted: #a59c8e;
        --color-accent: #d96b52;
        --color-accent-light: #3a2a25;
        --color-border: #3a342c;
        --color-nav-bg: rgba(28, 26, 23, 0.92);
        color-scheme: dark;
      }
    }

    :root[data-theme="dark"] {
      --color-bg: #1c1a17;
      --color-surface: #28241f;
      --color-text: #ece5da;
      --color-text-muted: #a59c8e;
      --color-accent: #d96b52;
      --color-accent-light: #3a2a25;
      --color-border: #3a342c;
      --color-nav-bg: rgba(28, 26, 23, 0.92);
      color-scheme: dark;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      font-size: 18px;
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font-body);
      color: var(--color-text);
      background: var(--color-bg);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    /* --- Navigation --- */
    .site-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--color-nav-bg);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--color-border);
      padding: 0.75rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .site-nav a {
      text-decoration: none;
      color: var(--color-text);
    }

    .site-nav .logo {
      font-family: var(--font-display);
      font-size: 1.1rem;
      letter-spacing: -0.01em;
    }

    .site-nav .nav-links {
      display: flex;
      gap: 1.5rem;
      list-style: none;
      font-size: 0.85rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .site-nav .nav-links a:hover {
      color: var(--color-accent);
    }

    .site-nav .nav-random,
    .site-nav .nav-theme {
      /* Style buttons so they read as peers of the nav links */
      background: none;
      border: none;
      padding: 0;
      font: inherit;
      color: inherit;
      cursor: pointer;
      letter-spacing: inherit;
      text-transform: inherit;
    }

    .site-nav .nav-random:hover,
    .site-nav .nav-theme:hover {
      color: var(--color-accent);
    }

    /* --- Main content --- */
    .page-container {
      max-width: 48rem;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    .page-container.wide {
      max-width: 64rem;
    }

    /* --- Typography for rendered markdown --- */
    .recipe-body h2 {
      font-family: var(--font-display);
      font-size: 1.6rem;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      color: var(--color-text);
    }

    .recipe-body h3 {
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 1.05rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-top: 2rem;
      margin-bottom: 0.5rem;
      color: var(--color-text-muted);
    }

    .recipe-body p {
      margin-bottom: 1rem;
    }

    .recipe-body ul, .recipe-body ol {
      margin: 0.5rem 0 1rem 1.5rem;
    }

    .recipe-body li {
      margin-bottom: 0.35rem;
    }

    .recipe-body strong {
      font-weight: 600;
    }

    .recipe-body em {
      font-style: italic;
    }

    .recipe-body hr {
      border: none;
      border-top: 1px solid var(--color-border);
      margin: 2rem 0;
    }

    /* --- Tier badges --- */
    .tier-badge {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.25rem 0.65rem;
      border-radius: 4px;
      color: white;
    }

    .tier-badge.chill { background: var(--tier-chill); }
    .tier-badge.legit { background: var(--tier-legit); }
    .tier-badge.real-deal { background: var(--tier-real-deal); }
    .tier-badge.ordeal { background: var(--tier-ordeal); }

    /* --- Redaction bars --- */
    /* The book swears; the website pleads the fifth. Hover to reveal.
       Real text stays in the DOM (transparent under the bar), so
       copy/paste and screen readers get the uncensored experience. */
    .redacted {
      background: var(--color-text);
      color: transparent;
      border-radius: 3px;
      transition: color 0.2s ease, background 0.2s ease;
    }

    .redacted:hover,
    .redacted:active {
      background: transparent;
      color: inherit;
    }

    .redacted::selection {
      color: transparent; /* stays coy even when selected — paste it to find out */
    }

    /* --- Footer --- */
    .site-footer {
      text-align: center;
      padding: 2rem;
      font-size: 0.8rem;
      color: var(--color-text-muted);
      border-top: 1px solid var(--color-border);
    }

    /* --- Responsive --- */
    @media (max-width: 640px) {
      html { font-size: 16px; }
      .site-nav { padding: 0.65rem 1rem; }
      .site-nav .nav-links { gap: 1rem; font-size: 0.75rem; }
      .page-container { padding: 1.5rem 1rem 3rem; }
    }
  </style>
</head>
<body>
  <nav class="site-nav" transition:persist>
    <a href="/" class="logo">Ice Cream to Fight With</a>
    <ul class="nav-links">
      <li><a href="/">Recipes</a></li>
      <li><a href="/search">Search</a></li>
      <li><a href="/about">About</a></li>
      <li><button type="button" id="random-recipe" class="nav-random">Surprise me</button></li>
      <li>
        <button type="button" id="theme-toggle" class="nav-theme" aria-label="Toggle color theme">
          <span class="theme-label">Auto</span>
        </button>
      </li>
    </ul>
  </nav>

  <script define:vars={{ recipeSlugs }}>
    // transition:persist keeps the nav across SPA navigations,
    // so these listeners only need to bind once.

    document.getElementById('random-recipe')?.addEventListener('click', () => {
      const slug = recipeSlugs[Math.floor(Math.random() * recipeSlugs.length)];
      window.location.href = `/recipes/${slug}/`;
    });

    // Theme toggle: cycles Auto -> Light -> Dark -> Auto
    (() => {
      const order = ['auto', 'light', 'dark'];
      const labels = { auto: 'Auto', light: 'Light', dark: 'Dark' };
      const btn = document.getElementById('theme-toggle');
      if (!btn) return;
      const labelEl = btn.querySelector('.theme-label');

      function readState() {
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'light' || saved === 'dark') return saved;
        } catch {}
        return 'auto';
      }

      function applyTheme(state) {
        if (state === 'auto') {
          delete document.documentElement.dataset.theme;
          try { localStorage.removeItem('theme'); } catch {}
        } else {
          document.documentElement.dataset.theme = state;
          try { localStorage.setItem('theme', state); } catch {}
        }
        if (labelEl) labelEl.textContent = labels[state];
      }

      // Sync label with the state the inline head script already applied
      if (labelEl) labelEl.textContent = labels[readState()];

      btn.addEventListener('click', () => {
        const current = readState();
        const next = order[(order.indexOf(current) + 1) % order.length];
        applyTheme(next);
      });
    })();
  </script>

  <slot />

  <footer class="site-footer" transition:persist>
    Ice Cream to Fight With &copy; {new Date().getFullYear()}
  </footer>
</body>
</html>
